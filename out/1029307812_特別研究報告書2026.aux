\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.3.2}棒の向きの分布と通過機構}{11}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces 広い断面（$x\approx 0.20$）における棒の向きの分布$P(\phi )$（$m=3$と$m=6$，いずれも$\beta pE=3$）．$\delta $が小さいと$\phi =\pi /2$（点線）に単峰，大きいと$\phi _1=\arcsin (1/\delta )$付近（軸方向）へ移動して二峰化する．}}{12}{}\protected@file@percent }
\newlabel{fig:pphi}{{2}{12}{}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces $(x,\phi )$占有マップ（$m=6$，$\beta pE=3$）．色は各位置$x$での条件付きの向きの分布$P(\phi \,|\,x)$．破線は最狭窄部$x\approx 0.81$，点線は$\phi =\pi /2$．$\delta =1/3$（上）では棒は広域で$\phi =\pi /2$に揃うが最狭窄部でのみ軸方向に選別され，$\delta =10$（下）では全域で軸方向に傾いて最狭窄部を乱されずに通過する．}}{13}{}\protected@file@percent }
\newlabel{fig:xphi}{{3}{13}{}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces 広い断面における占有重み付き$\langle |\sin \phi |\rangle $の$\delta $依存性．破線は安定な向き$\sin \phi _1=1/\delta $から定まる理論値$\min (1,1/\delta )$．}}{14}{}\protected@file@percent }
\newlabel{fig:orientation}{{4}{14}{}{figure.4}{}}
