\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces 平均速度$v=L/T_1$（上段）と有効拡散係数$D_{\mathrm   {eff}}$（下段）の$\delta =|\Delta \alpha |E/p$依存性．左列が$m=3$，右列が$m=6$．記号は永久双極子と熱エネルギーの比$\beta pE$を表す．誤差棒は初通過時間のブートストラップ標準誤差，破線は傾いた向きが最狭窄部に収まる幾何閾値（$m=3$で$\delta =1$，$m=6$で$\delta =2$）を示す．}}{11}{}\protected@file@percent }
